# ============================================================
#  .env – Environment Variables
#  Student Home Visit Map System
#
#  ⚠️  อย่า commit ไฟล์นี้ขึ้น Git (เพิ่มใน .gitignore)
# ============================================================

# ── Database ─────────────────────────────────────────────────
DB_HOST=localhost
DB_NAME=student_map
DB_USER=แก้ชื่อผู้ใช้ของคุณ
DB_PASS=แก้รหัสผ่านของคุณ
DB_CHARSET=utf8mb4

# รหัสผ่านสำหรับแผนที่
MAP_PASSWORD=map123

# ── Application ──────────────────────────────────────────────
APP_NAME=ระบบแผนที่เยี่ยมบ้านนักเรียน
APP_VERSION=1.0.0

# ── Base URL (ไม่มี trailing slash) ──────────────────────────
# Local:
BASE_URL=แก้เป็นชื่อdomainของคุณ/student_map
# Production example:
# BASE_URL=https://แก้เป็นชื่อdomainของคุณ

# ── Upload settings ───────────────────────────────────────────
MAX_FILE_SIZE_MB=5
